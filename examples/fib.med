#128;

P : main; // main()

fib: // fib(n)
	C1 = 0; // a
	C2 = 1; // b
	C3 = 0; // next

	C4 = 1; // i
	[~ // while(1) {
		%%C1; // printf("%d", a);
		C3 = C1 + C2; // next = a + b;
		C1 = C2; // a = b;
		C2 = C3; // b = next;

		C4 > C0 ^; // if i > n: break;
		C4++; // i++;
	] // }

	P : ret; // return;

main:
	C0 = 3; // n
	P : fib; // fib(n)
	%"Program complete!\nFib " %%C0 %" is " %%C1;
ret:

